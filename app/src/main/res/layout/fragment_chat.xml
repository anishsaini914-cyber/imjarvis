<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_messages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="12dp" />

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/neon_blue"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:padding="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_clear"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:icon="@drawable/ic_delete"
            app:iconTint="@color/on_surface_variant" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/glass_card"
            android:backgroundTint="@color/surface_light"
            android:hint="@string/chat_placeholder"
            android:maxLines="4"
            android:padding="12dp"
            android:textColor="@color/on_surface"
            android:textColorHint="@color/on_surface_variant" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_voice_input"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:icon="@drawable/ic_mic"
            app:iconTint="@color/on_surface_variant" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_send"
            android:layout_width="48dp"
            android:layout_height="40dp"
            android:icon="@drawable/ic_send"
            app:cornerRadius="20dp"
            app:iconTint="@color/white" />

    </LinearLayout>

</LinearLayout>

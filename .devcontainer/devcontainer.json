{
  "name": "Android Dev Container",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "fwcd.kotlin",
        "redhat.java"
      ]
    }
  },
  "postCreateCommand": "chmod +x gradlew || true",
  "remoteUser": "root"
}
